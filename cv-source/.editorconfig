root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,tex,bib}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{py,toml,yml,yaml,json,md,tex,bib,sty,txt}]
indent_style = space
indent_size = 2

[*.py]
indent_size = 4
