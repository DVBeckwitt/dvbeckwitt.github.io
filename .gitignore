# Ignore docs files
_site
_drafts
build
dist
__pycache__
*.py[cod]
*.pyo

# Numerous always-ignore extensions
*.diff
*.err
*.orig
*.log
*.rej
*.swo
*.swp
*.vi
*~

# OS or Editor folders
.DS_Store
._*
Thumbs.db
.cache
.project
.settings
.tmproj
*.esproj
nbproject
*.sublime-project
*.sublime-workspace
.idea

# Folders to ignore
node_modules
package-lock.json
vendor
.sass-cache
.jekyll-metadata
.jekyll-cache
.ruby-lsp
.wrangler
.pytest_cache
.ruff_cache
.mypy_cache
.coverage
.coverage.*
coverage
coverage.xml
htmlcov
.venv
venv
env
ENV
*.gem
*.egg-info
Gemfile.lock
_zip
/stats.json
.dev.vars

/assets/js/*hydejack-*
/_sass/*/__*__/*
/assets/docs/*.pdf

# LaTeX outputs
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.run.xml
*.synctex.gz
comment.cut

# CV source private/generated outputs
/cv-source/build/
/cv-source/docs/compiled/*.pdf
/cv-source/applications/examples/**/originals/
/cv-source/main.pdf
/cv-source/applications/examples/teaching/teaching_philosophy_example.pdf
/cv-source/outputs/**
!/cv-source/outputs/
!/cv-source/outputs/README.md
/cv-source/private/
/cv-source/local/
/cv-source/scratch/
/cv-source/tmp/
/cv-source/temp/
